graph TB
    subgraph External["External Services"]
        Telegram[Telegram Bot API]
        Alpaca[Alpaca Broker API]
        Tiingo[Tiingo Data & News API]
        LLMProvider[OpenAI / DeepSeek]
    end

    subgraph TradingSystem["Trading System Core"]
        Main[main.py<br/>Entry Point]
        TS[TradingSystem<br/>Orchestrator]
        
        subgraph EventSys["Event System"]
            ES[EventSystem<br/>Priority Queue<br/>Async Processing]
        end
        
        subgraph Workflow["LLM Agent Workflow"]
            LLM[LLM Portfolio Agent<br/>ReAct Agent<br/>Autonomous Decision]
            
            subgraph Tools["11 Agent Tools"]
                T1[get_current_time]
                T2[check_market_status]
                T3[get_portfolio_status]
                T4[get_market_data]
                T5[get_latest_news]
                T6[get_position_analysis]
                T7[get_latest_price]
                T8[get_historical_prices]
                T9[adjust_position]
                T10[rebalance_portfolio]
                T11[schedule_next_analysis]
            end
        end
        
        subgraph Services["Background Services"]
            Scheduler[Task Scheduler<br/>Daily Triggers]
            MM[Message Manager<br/>Notification Router]
        end
        
        subgraph Adapters["API Adapters"]
            BA[Broker Adapter<br/>Alpaca]
            MDA[Market Data Adapter<br/>Tiingo]
            NA[News Adapter<br/>Tiingo]
            TeleService[Telegram Service<br/>Commands & Callbacks]
        end
    end

    %% Main initialization flow
    Main -->|Initialize & Start| TS
    TS -->|Register Handlers| ES
    TS -->|Start Scheduler| Scheduler
    TS -->|Initialize| TeleService
    
    %% Event publishing flows
    Scheduler -->|Publish Events| ES
    TeleService -->|Publish Events| ES
    
    %% Event handling flows
    ES -->|trigger_workflow| TS
    ES -->|enable/disable_trading| TS
    ES -->|query_status| TS
    ES -->|emergency_stop| TS
    
    %% Workflow execution
    TS -->|Execute| LLM
    
    %% LLM tool usage
    LLM -->|Use Tools| T1
    LLM -->|Use Tools| T2
    LLM -->|Use Tools| T3
    LLM -->|Use Tools| T4
    LLM -->|Use Tools| T5
    LLM -->|Use Tools| T6
    LLM -->|Use Tools| T7
    LLM -->|Use Tools| T8
    LLM -->|Use Tools| T9
    LLM -->|Use Tools| T10
    LLM -->|Use Tools| T11
    
    %% Tool to API connections
    T3 & T4 & T7 & T8 & T9 & T10 -->|API Calls| BA
    T4 & T7 & T8 -->|API Calls| MDA
    T5 -->|API Calls| NA
    T11 -->|Schedule Event| ES
    
    %% External API connections
    BA <-->|REST API| Alpaca
    MDA <-->|REST API| Tiingo
    NA <-->|REST API| Tiingo
    TeleService <-->|Bot API| Telegram
    LLM <-->|API Calls| LLMProvider
    
    %% Notification flows
    LLM -->|Send Messages| MM
    TS -->|Send Messages| MM
    MM -->|Route Messages| TeleService
    TeleService -->|Send| Telegram

    %% Styling
    classDef coreClass fill:#4A90E2,stroke:#2E5C8A,stroke-width:2px,color:#fff
    classDef eventClass fill:#50C878,stroke:#2D7A4A,stroke-width:2px,color:#fff
    classDef llmClass fill:#9B59B6,stroke:#6C3483,stroke-width:2px,color:#fff
    classDef toolClass fill:#E67E22,stroke:#A04000,stroke-width:2px,color:#fff
    classDef adapterClass fill:#F39C12,stroke:#B8860B,stroke-width:2px,color:#fff
    classDef externalClass fill:#95A5A6,stroke:#5D6D7E,stroke-width:2px,color:#fff
    classDef serviceClass fill:#3498DB,stroke:#2C3E50,stroke-width:2px,color:#fff
    
    class TS,Main coreClass
    class ES eventClass
    class LLM llmClass
    class T1,T2,T3,T4,T5,T6,T7,T8,T9,T10,T11 toolClass
    class BA,MDA,NA,TeleService adapterClass
    class Telegram,Alpaca,Tiingo,LLMProvider externalClass
    class Scheduler,MM serviceClass
