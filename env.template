# Trading Agent Environment Variables
# Copy this file to .env and update with your actual values

# ========== 数据目录 ==========
DATA_DIR=./user_data

# ========== 交易 API ==========

# Alpaca
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Interactive Brokers (可选)
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1

# ========== 市场数据 API ==========

# Tiingo
TIINGO_API_KEY=your_tiingo_api_key

# Finnhub
FINNHUB_API_KEY=your_finnhub_api_key

# Unusual Whales (可选)
# UNUSUAL_WHALES_API_KEY=your_unusual_whales_api_key

# ========== 提供商配置 ==========

BROKER_PROVIDER=alpaca
MARKET_DATA_PROVIDER=tiingo
REALTIME_DATA_PROVIDER=finnhub
NEWS_PROVIDERS=tiingo,finnhub
MESSAGE_PROVIDER=telegram

# ========== LLM 配置 (OpenAI 兼容格式) ==========

# 主 LLM (Agent Workflow 使用)
# 支持任何 OpenAI 兼容 API：OpenAI、DeepSeek、Ollama 等
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o

# 示例：使用 DeepSeek
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=your_deepseek_api_key
# LLM_MODEL=deepseek-chat

# 示例：使用本地 Ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3

# 新闻过滤 LLM (独立配置，可用便宜模型)
# 如果不配置，使用主 LLM
# NEWS_LLM_BASE_URL=https://api.deepseek.com/v1
# NEWS_LLM_API_KEY=your_deepseek_api_key
# NEWS_LLM_MODEL=deepseek-chat

# ========== Workflow 配置 ==========

# 可选: llm_portfolio, black_litterman, cognitive_arbitrage
WORKFLOW_TYPE=llm_portfolio

# ========== Telegram 配置 ==========

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ========== 交易参数 ==========

PAPER_TRADING=true
MAX_POSITION_SIZE=0.1
MAX_POSITIONS=10

# ========== 风险管理 ==========

RISK_MANAGEMENT_ENABLED=true
STOP_LOSS_PERCENTAGE=0.05
TAKE_PROFIT_PERCENTAGE=0.15
DAILY_LOSS_LIMIT_PERCENTAGE=0.10
MAX_POSITION_CONCENTRATION=0.25

# ========== 告警阈值 ==========

# 组合日盈亏超过此比例触发告警 (0.05 = 5%)
PORTFOLIO_PNL_ALERT_THRESHOLD=0.05
# 单个持仓浮亏超过此比例触发告警 (0.10 = 10%)
POSITION_LOSS_ALERT_THRESHOLD=0.10

# ========== 时区配置 ==========

TRADING_TIMEZONE=US/Eastern
EXCHANGE=XNYS
REBALANCE_TIME=09:30
EOD_ANALYSIS_TIME=16:05

# ========== 实时监控 ==========

PRICE_CHANGE_THRESHOLD=5.0
VOLATILITY_THRESHOLD=8.0
REBALANCE_COOLDOWN_SECONDS=3600
# 市场 ETF（用于新闻覆盖），逗号分隔
MARKET_ETFS=SPY,QQQ,IWM

# ========== 调度间隔 (分钟) ==========

PORTFOLIO_CHECK_INTERVAL=60
RISK_CHECK_INTERVAL=15
# 同类型 workflow 最小执行间隔（分钟）
MIN_WORKFLOW_INTERVAL_MINUTES=30
# APScheduler misfire grace time（秒）
SCHEDULER_MISFIRE_GRACE_TIME=60
# 调度器执行历史最大保留条数
SCHEDULER_MAX_HISTORY=200
# LLM 自主调度最大待执行任务数
MAX_PENDING_LLM_JOBS=5
# 消息发送速率限制（每秒条数）
MESSAGE_RATE_LIMIT=1.0

# ========== LLM Agent 配置 ==========

# ReAct Agent 最大递归深度
LLM_RECURSION_LIMIT=64
# 分析历史最大保留条数
LLM_MAX_ANALYSIS_HISTORY=50
# 历史摘要最大 token 数
LLM_MAX_SUMMARY_TOKENS=1500

# ========== 交易执行配置 ==========

# 最小调整市值阈值 ($)
REBALANCE_MIN_VALUE_THRESHOLD=20.0
# 最小调整百分比阈值 (%)
REBALANCE_MIN_PCT_THRESHOLD=1.0
# 买入时预留资金比例
REBALANCE_BUY_RESERVE_RATIO=0.95
# 权重差异阈值（BL 模式）
REBALANCE_WEIGHT_DIFF_THRESHOLD=0.02
# 连续下单间隔秒数
REBALANCE_ORDER_DELAY_SECONDS=1.0
# 现金关键词（逗号分隔）
CASH_KEYWORDS=CASH,USD,DOLLAR

# ========== Black-Litterman 配置 ==========

BL_RISK_AVERSION=2.5
BL_HISTORICAL_DAYS=252
BL_BASE_VARIANCE=0.05
BL_MIN_WEIGHT=0.01
# 默认资产池（逗号分隔）
BL_DEFAULT_UNIVERSE=SPY,QQQ,IWM,AAPL,MSFT,GOOGL,NVDA,AMD,META,GLD,TLT,XLF,XLE

# ========== API 配置 ==========

API_HOST=0.0.0.0
API_PORT=8000
# CORS 允许的来源，逗号分隔
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ========== 鉴权配置 ==========
# 用户名
AUTH_USERNAME=admin
# bcrypt 哈希密码（通过 python scripts/hash_password.py 生成）
# 留空 = 鉴权关闭（开发模式下无需登录）
AUTH_PASSWORD_HASH=
# JWT 签名密钥（生产环境必须修改为随机字符串）
JWT_SECRET_KEY=CHANGE-ME-TO-A-RANDOM-STRING
JWT_ALGORITHM=HS256
# Token 有效期（分钟），默认 24 小时
JWT_EXPIRE_MINUTES=1440

# ========== 记忆 DB 配置 (PostgreSQL — LangGraph Memory) ==========
POSTGRES_DB=trading_memory
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
# 开发模式使用 docker-compose.dev.yml 启动 Postgres，连接 localhost:5432
# 生产模式由 docker-compose.yml 自动设置（通过 service name 连接）
# POSTGRES_URI=postgresql://trading:trading@localhost:5432/trading_memory

# ========== 日志 ==========

LOG_LEVEL=INFO
LOG_TO_FILE=true
ENVIRONMENT=development

# Cloudflare Token
CF_TUNNEL_TOKEN=
