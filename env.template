# TradeClaw Environment Variables
# Copy this file to .env and update with your actual values

# ========== Data Directory ==========
DATA_DIR=./user_data

# ========== Trading API ==========

# Alpaca
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Interactive Brokers (optional)
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1

# ========== Market Data API ==========

# Tiingo
TIINGO_API_KEY=your_tiingo_api_key

# Finnhub (optional)
# FINNHUB_API_KEY=your_finnhub_api_key

# Unusual Whales (optional)
# UNUSUAL_WHALES_API_KEY=your_unusual_whales_api_key

# ========== Provider Configuration ==========

BROKER_PROVIDER=alpaca
MARKET_DATA_PROVIDER=tiingo
# Leave empty if you don't have a real-time data provider
REALTIME_DATA_PROVIDER=
# akshare is free (no API key needed); add alpaca/tiingo/finnhub if you have keys
NEWS_PROVIDERS=akshare
MESSAGE_PROVIDER=telegram

# ========== LLM Configuration (OpenAI-compatible) ==========

# Primary LLM (used by Agent Workflows)
# Supports any OpenAI-compatible API: OpenAI, DeepSeek, Ollama, etc.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o

# Example: DeepSeek
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=your_deepseek_api_key
# LLM_MODEL=deepseek-chat

# Example: Local Ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3

# News Filter LLM (separate config, can use a cheaper model)
# If not set, falls back to the primary LLM
# NEWS_LLM_BASE_URL=https://api.deepseek.com/v1
# NEWS_LLM_API_KEY=your_deepseek_api_key
# NEWS_LLM_MODEL=deepseek-chat

# ========== Workflow Configuration ==========

# Options: llm_portfolio, black_litterman, cognitive_arbitrage
WORKFLOW_TYPE=llm_portfolio

# ========== Telegram Configuration ==========

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ========== Trading Parameters ==========

PAPER_TRADING=true

# ========== Risk Management ==========

RISK_MANAGEMENT_ENABLED=true
STOP_LOSS_PERCENTAGE=0.05
TAKE_PROFIT_PERCENTAGE=0.15
DAILY_LOSS_LIMIT_PERCENTAGE=0.10
MAX_POSITION_CONCENTRATION=0.25

# ========== Alert Thresholds ==========

# Portfolio daily PnL exceeding this ratio triggers an alert (0.05 = 5%)
PORTFOLIO_PNL_ALERT_THRESHOLD=0.05
# Single position unrealized loss exceeding this ratio triggers an alert (0.10 = 10%)
POSITION_LOSS_ALERT_THRESHOLD=0.10

# ========== Timezone Configuration ==========

TRADING_TIMEZONE=US/Eastern
EXCHANGE=XNYS
REBALANCE_TIME=09:30
EOD_ANALYSIS_TIME=16:05

# ========== News Polling ==========

# Polling interval in minutes (0 = disabled)
NEWS_POLL_INTERVAL_MINUTES=5
# Max articles fetched per poll
NEWS_POLL_MAX_PER_BATCH=20
# LLM scores each article 0-10; only articles >= threshold trigger the trading workflow
NEWS_IMPORTANCE_THRESHOLD=7

# ========== Real-Time Monitoring ==========

PRICE_CHANGE_THRESHOLD=5.0
VOLATILITY_THRESHOLD=8.0
REBALANCE_COOLDOWN_SECONDS=3600
# Market ETFs for news coverage (comma-separated)
MARKET_ETFS=SPY,QQQ,IWM

# ========== Scheduling Intervals (minutes) ==========

PORTFOLIO_CHECK_INTERVAL=60
RISK_CHECK_INTERVAL=15
# Minimum interval between same-type workflow executions (minutes)
MIN_WORKFLOW_INTERVAL_MINUTES=30
# APScheduler misfire grace time (seconds)
SCHEDULER_MISFIRE_GRACE_TIME=60
# Max scheduler execution history entries
SCHEDULER_MAX_HISTORY=200
# Max pending LLM-scheduled jobs
MAX_PENDING_LLM_JOBS=5
# Message sending rate limit (messages per second)
MESSAGE_RATE_LIMIT=1.0

# ========== LLM Agent Configuration ==========

# ReAct Agent max recursion depth
LLM_RECURSION_LIMIT=64
# Max analysis history entries
LLM_MAX_ANALYSIS_HISTORY=50
# Max tokens for history summary
LLM_MAX_SUMMARY_TOKENS=1500

# ========== Trade Execution Configuration ==========

# Minimum adjustment value threshold ($)
REBALANCE_MIN_VALUE_THRESHOLD=20.0
# Minimum adjustment percentage threshold (%)
REBALANCE_MIN_PCT_THRESHOLD=1.0
# Reserve ratio when buying
REBALANCE_BUY_RESERVE_RATIO=0.95
# Weight difference threshold (BL mode)
REBALANCE_WEIGHT_DIFF_THRESHOLD=0.02
# Delay between consecutive orders (seconds)
REBALANCE_ORDER_DELAY_SECONDS=1.0
# Cash keywords (comma-separated)
CASH_KEYWORDS=CASH,USD,DOLLAR

# ========== Black-Litterman Configuration ==========

BL_RISK_AVERSION=2.5
BL_HISTORICAL_DAYS=252
BL_BASE_VARIANCE=0.05
BL_MIN_WEIGHT=0.01
# Default asset universe (comma-separated)
BL_DEFAULT_UNIVERSE=SPY,QQQ,IWM,AAPL,MSFT,GOOGL,NVDA,AMD,META,GLD,TLT,XLF,XLE

# ========== API Configuration ==========

API_HOST=0.0.0.0
API_PORT=8000
# CORS allowed origins (comma-separated)
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ========== Authentication ==========
# Username
AUTH_USERNAME=admin
# bcrypt hashed password (generate via: python scripts/hash_password.py)
# Leave empty = auth disabled (no login required in dev mode)
AUTH_PASSWORD_HASH=
# JWT signing secret (MUST change to a random string in production)
JWT_SECRET_KEY=CHANGE-ME-TO-A-RANDOM-STRING
JWT_ALGORITHM=HS256
# Token expiration (minutes), default 24 hours
JWT_EXPIRE_MINUTES=1440

# ========== Memory DB (PostgreSQL — LangGraph Memory) ==========
POSTGRES_DB=trading_memory
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
# Dev mode: start Postgres via docker-compose.dev.yml, connect to localhost:5432
# Production: docker-compose.yml sets this automatically via service name
# POSTGRES_URI=postgresql://trading:trading@localhost:5432/trading_memory

# ========== Web Search Tool ==========
SEARXNG_BASE_URL=http://localhost:8080

# ========== OpenSandbox (Docker-based code sandbox) ==========
# The opensandbox-server runs as a Docker service (see docker-compose.yml).
# In docker-compose mode this is set automatically via the service environment.
# For local dev, start opensandbox-server and set the URL here:
OPENSANDBOX_SERVER_URL=http://localhost:8080
# Optional API key for opensandbox-server authentication
# OPEN_SANDBOX_API_KEY=

# ========== Playwright MCP (Browser Automation) ==========
# Playwright MCP Server runs as a Docker sidecar (mcr.microsoft.com/playwright/mcp).
# In docker-compose mode this is set automatically via the service environment.
# For local dev: docker compose -f docker-compose.dev.yml up playwright-mcp
PLAYWRIGHT_MCP_URL=http://localhost:8931

# ========== Embedding Configuration (Memory Semantic Search) ==========
# Provider: "openai" uses any OpenAI-compatible embedding API
# If not set, memory search falls back to time-based retrieval (no semantic search)
# Dims are auto-detected at startup — no need to configure manually.
# EMBEDDING_PROVIDER=openai

# DashScope (Alibaba Cloud / Qwen)
# EMBEDDING_API_KEY=sk-your-dashscope-key
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v3

# OpenAI
# EMBEDDING_API_KEY=sk-your-openai-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# Local Ollama
# EMBEDDING_API_KEY=ollama
# EMBEDDING_BASE_URL=http://localhost:11434/v1
# EMBEDDING_MODEL=nomic-embed-text

# ========== Logging ==========

LOG_LEVEL=INFO
LOG_TO_FILE=true
ENVIRONMENT=development

# ========== Cloudflare Tunnel (optional) ==========
CF_TUNNEL_TOKEN=
